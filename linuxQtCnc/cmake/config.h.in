#ifndef CONFIG_H
#define CONFIG_H

// ========================================================================
// Platform detection for config.h
// CMake defines LQTCNC_IS_WINDOWS / LQTCNC_IS_LINUX in the build system.
// ========================================================================
#cmakedefine01 LQTCNC_IS_WINDOWS
#cmakedefine01 LQTCNC_IS_LINUX

// ========================================================================
// Package info
// ========================================================================
#define PACKAGE_NAME "linuxQtCnc"
#define PACKAGE_VERSION "@PROJECT_VERSION@"
#define PACKAGE_STRING "@PROJECT_NAME@ @PROJECT_VERSION@"
#define PACKAGE_TARNAME "@PROJECT_NAME@"

// ========================================================================
// Build mode - always ULAPI (user-space) for linuxQtCnc
// ========================================================================
#define RTAPI_USPACE 1
#define ULAPI 1

// ========================================================================
// Paths
// ========================================================================
#define EMC2_HOME "@CMAKE_INSTALL_PREFIX@"
#define EMC2_BIN_DIR "@CMAKE_INSTALL_PREFIX@/bin"
#define EMC2_RTLIB_DIR "@CMAKE_INSTALL_PREFIX@/lib/linuxcnc/rtlib"
#define EMC2_PO_DIR "@CMAKE_INSTALL_PREFIX@/share/locale"
#if defined(_WIN32) || defined(WIN32)
    #define EMC2_TMP_DIR "@CMAKE_INSTALL_PREFIX@/tmp"
#else
    #define EMC2_TMP_DIR "/tmp/linuxcnc"
#endif
#define EMC2_NCFILES_DIR "@CMAKE_INSTALL_PREFIX@/share/linuxcnc/ncfiles"
#define EMC2_DEFAULT_NMLFILE "@CMAKE_INSTALL_PREFIX@/etc/linuxcnc/default.nml"
#define EMC2_DEFAULT_TOOLTABLE "@CMAKE_INSTALL_PREFIX@/share/linuxcnc/tool.tbl"

// ========================================================================
// Module extension
// ========================================================================
#if defined(_WIN32) || defined(WIN32)
    #define MODULE_EXT ".dll"
#else
    #define MODULE_EXT ".so"
#endif

// ========================================================================
// Runtime directory
// ========================================================================
#if defined(_WIN32) || defined(WIN32)
    #define RTDIR "@CMAKE_INSTALL_PREFIX@/dev"
#else
    #define RTDIR "/dev"
#endif

// ========================================================================
// Feature detection
// ========================================================================
#cmakedefine01 HAVE_SYS_IO_H
#cmakedefine01 HAVE_CLOCK_NANOSLEEP
#cmakedefine01 HAVE_SEMTIMEDOP
#cmakedefine01 HAVE_OPTRESET
#cmakedefine01 HAVE_LOCALE_H
#cmakedefine01 HAVE_LIBINTL_H
#cmakedefine01 HAVE_SETLOCALE
#cmakedefine01 HIDRAW_H_USABLE
#cmakedefine01 LIBGPIOD_VER
#cmakedefine01 HAVE_DLFCN_H

// ========================================================================
// Linux / POSIX only
// ========================================================================
#if !defined(_WIN32) && !defined(WIN32)
    #define LIBDL 1
    #define _GNU_SOURCE 1
#endif

#endif // CONFIG_H
